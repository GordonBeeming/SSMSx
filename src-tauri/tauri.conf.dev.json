{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SSMSx Dev",
  "identifier": "com.ssmsx.app.dev",
  "app": {
    "windows": [
      {
        "title": "SSMSx Dev",
        "width": 1400,
        "height": 900,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "dev-mcp",
          "description": "Development capabilities for SSMSx MCP smoke testing",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "mcp-bridge:default",
            "shell:allow-open",
            "shell:allow-spawn"
          ]
        }
      ]
    },
    "withGlobalTauri": true
  }
}
