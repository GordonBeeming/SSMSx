{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/explorer/**",
              "components/navigation/**",
              "components/overlay/**",
              "ui_kits/ssmsx-desktop/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|leadingIcon|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, leadingIcon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ConnectionItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|serverName|database|username|authType|color|selected|onClick|onDoubleClick|style|key|ref|className|style|children)$/]",
        "message": "<ConnectionItem> doesn't accept that prop. Declared props: name, serverName, database, username, authType, color, selected, onClick, onDoubleClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContextMenuItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|onClick|danger|disabled|separator|key|ref|className|style|children)$/]",
        "message": "<ContextMenuItem> doesn't accept that prop. Declared props: label, onClick, danger, disabled, separator."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Input> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NodeIcon'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|folderKind|size|style|key|ref|className|style|children)$/]",
        "message": "<NodeIcon> doesn't accept that prop. Declared props: type, folderKind, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='QueryTab'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|database|kind|active|dirty|color|onSelect|onClose|style|key|ref|className|style|children)$/]",
        "message": "<QueryTab> doesn't accept that prop. Declared props: title, database, kind, active, dirty, color, onSelect, onClose, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='QueryTab'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:query|diagram)$/]",
        "message": "<QueryTab> kind must be one of 'query' | 'diagram'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TreeRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|label|depth|expanded|hasChildren|loading|selected|color|onToggle|onSelect|style|key|ref|className|style|children)$/]",
        "message": "<TreeRow> doesn't accept that prop. Declared props: type, label, depth, expanded, hasChildren, loading, selected, color, onToggle, onSelect, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "Badge": {
        "replaces": []
      },
      "Button": {
        "replaces": []
      },
      "ConnectionItem": {
        "replaces": []
